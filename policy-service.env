# ===============================================================================
# policy-service.env — 由 generate-envs.sh 自动生成
# 编辑 shared.env 和 policy-service.env.tpl 后重新运行此脚本即可更新
# 最后生成时间: 2026-07-10 14:49:34
# ===============================================================================

# ── 以下变量来自 shared.env ──
# =============================================================================
# shared.env — 跨服务共享的环境变量
# 此文件被 generate-envs.sh 合并到每个服务的最终 .env 文件中
# 如某个服务需要不同的值，在对应的 .env.tpl 中定义即可覆盖
# =============================================================================

# --- 数据库连接 (所有服务通用) ---
POSTGRES_DATABASE_URL=postgresql://alephant:<数据库密码>@postgres:5432/alephant

# --- Redis 连接 (所有服务通用) ---
REDIS_URL=redis://default:<Redis密码>@valkey:6379/0

# --- JWT 密钥 (saas-service, ai-gateway, logs-collector) ---
JWT_SECRET=<请替换>

# --- 日志收集内部认证 (saas-service, ai-gateway, ledge-service, logs-collector) ---
LOGS_COLLECTOR_X402_HTTP_AUTH_TOKEN=<请替换>

# --- 支付服务密钥 (saas-service, ai-gateway, ledge-service) ---
PAYMENT_SERVICE_KEY=<请替换>

# --- 主密钥加密密钥 (saas-service, ai-gateway) ---
MASTER_KEY_ENCRYPTION_KEY=<请替换>

# --- 加密密钥 (ai-gateway, logs-collector) ---
ENCRYPTION_KEY=<请替换>

# --- S3 对象存储 (ai-gateway, logs-collector) ---
S3_ENDPOINT=<请替换>
S3_REGION=<请替换>
S3_BUCKET_NAME=<请替换>
S3_ACCESS_KEY=<请替换>
S3_SECRET_KEY=<请替换>

# --- ClickHouse (ai-gateway, logs-collector) ---
CLICKHOUSE_CREDS=default:<ClickHouse密码>

# --- 分析 (ai-gateway, logs-collector) ---
ANALYTICS_RMT_MAX_RANGE_HOURS=72

# --- 邮件配置 (saas-service, policy-service) ---
MAIL_HOST=<smtp.example.com>
MAIL_PORT=587
MAIL_USERNAME=<请替换>
MAIL_PASSWORD=<请替换>
MAIL_FROM_ADDRESS=<noreply@example.com>
MAIL_FROM_NAME=Alephant

# --- 通知 (saas-service, policy-service) ---
NOTIFICATION_ENCRYPTION_KEY=<请替换>
NOTIFICATION_OUTBOX_NOTIFY_CHANNEL=<请替换>

# --- Policy 流 (saas-service, policy-service) ---
POLICY_CONFIG_STREAM=<请替换>
POLICY_NOTIFY_CHANNEL=<请替换>

# --- Managed Wallets 通用 (saas-service, ledge-service) ---
MANAGED_WALLETS_ENABLED=true
MANAGED_WALLETS_ENVIRONMENT=production
MANAGED_WALLETS_PLATFORM_FEE_DESTINATION_TREASURY_BASE=<请替换>
MANAGED_WALLETS_PLATFORM_FEE_DESTINATION_TREASURY_SOLANA=<请替换>
MANAGED_WALLETS_PLATFORM_FEE_WITHDRAW_CREATE_ENABLED=true

# --- HMAC (saas-service, ledge-service) ---
OUTBOUND_PAYMENT_HMAC_SECRET=<请替换>
REVENUE_WITHDRAW_HMAC_SECRET=<请替换>

# --- X402 平台费 (saas-service, ledge-service) ---
X402_PLATFORM_FEE_BPS=50

# ── 以下变量来自 policy-service.env.tpl (可覆盖 shared.env) ──
# =============================================================================
# policy-service.env.tpl — 策略后端独有变量
# 与 shared.env 合并后生成 policy-service.env
# =============================================================================

# --- Policy ---
POLICY_USE_STREAM=true
POLICY_STREAM_BATCH_SIZE=100
POLICY_STREAM_BLOCK_MS=1000
POLICY_STREAM_CONSUMER_GROUP=<请替换>
POLICY_STREAM_CONSUMER_NAME=<请替换>
POLICY_BOOTSTRAP_REFRESH=true
POLICY_BOOTSTRAP_REFRESH_CONCURRENCY=10
POLICY_BOOTSTRAP_REFRESH_TIMEOUT_SEC=30
ENDPOINT_POLICY_CONFIG_STREAM=<请替换>
WATCHER_ENABLED=true

# --- Redis 专属 ---
REDIS_DB=0

# --- 日志 ---
LOG_LEVEL=info
