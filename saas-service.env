# ── 以下变量来自 shared.env ──
# =============================================================================
# shared.env — 跨服务共享的环境变量
# 此文件被 generate-envs.sh 合并到每个服务的最终 .env 文件中
# 如某个服务需要不同的值，在对应的 .env.tpl 中定义即可覆盖
# =============================================================================

# --- 数据库连接 (所有服务通用) ---
POSTGRES_DATABASE_URL=postgresql://alephant:<数据库密码>@postgres:5432/alephant

# --- Redis 连接 (所有服务通用) ---
REDIS_URL=redis://default:<Redis密码>@valkey:6379/0

# --- JWT 密钥 (saas-service, ai-gateway, logs-collector) ---
JWT_SECRET=<请替换>

# --- 日志收集内部认证 (saas-service, ai-gateway, ledge-service, logs-collector) ---
LOGS_COLLECTOR_X402_HTTP_AUTH_TOKEN=<请替换>

# --- 支付服务密钥 (saas-service, ai-gateway, ledge-service) ---
PAYMENT_SERVICE_KEY=<请替换>

# --- 主密钥加密密钥 (saas-service, ai-gateway) ---
MASTER_KEY_ENCRYPTION_KEY=<请替换>

# --- 加密密钥 (ai-gateway, logs-collector) ---
ENCRYPTION_KEY=<请替换>

# --- S3 对象存储 (ai-gateway, logs-collector) ---
S3_ENDPOINT=<请替换>
S3_REGION=<请替换>
S3_BUCKET_NAME=<请替换>
S3_ACCESS_KEY=<请替换>
S3_SECRET_KEY=<请替换>

# --- ClickHouse (ai-gateway, logs-collector) ---
CLICKHOUSE_CREDS=default:<ClickHouse密码>

# --- 分析 (ai-gateway, logs-collector) ---
ANALYTICS_RMT_MAX_RANGE_HOURS=72

# --- 邮件配置 (saas-service, policy-service) ---
MAIL_HOST=<smtp.example.com>
MAIL_PORT=587
MAIL_USERNAME=<请替换>
MAIL_PASSWORD=<请替换>
MAIL_FROM_ADDRESS=<noreply@example.com>
MAIL_FROM_NAME=Alephant

# --- 通知 (saas-service, policy-service) ---
NOTIFICATION_ENCRYPTION_KEY=<请替换>
NOTIFICATION_OUTBOX_NOTIFY_CHANNEL=<请替换>

# --- Policy 流 (saas-service, policy-service) ---
POLICY_CONFIG_STREAM=<请替换>
POLICY_NOTIFY_CHANNEL=<请替换>

# --- Managed Wallets 通用 (saas-service, ledge-service) ---
MANAGED_WALLETS_ENABLED=true
MANAGED_WALLETS_ENVIRONMENT=production
MANAGED_WALLETS_PLATFORM_FEE_DESTINATION_TREASURY_BASE=<请替换>
MANAGED_WALLETS_PLATFORM_FEE_DESTINATION_TREASURY_SOLANA=<请替换>
MANAGED_WALLETS_PLATFORM_FEE_WITHDRAW_CREATE_ENABLED=true

# --- HMAC (saas-service, ledge-service) ---
OUTBOUND_PAYMENT_HMAC_SECRET=<请替换>
REVENUE_WITHDRAW_HMAC_SECRET=<请替换>

# --- X402 平台费 (saas-service, ledge-service) ---
X402_PLATFORM_FEE_BPS=50

# ── 以下变量来自 saas-service.env.tpl (可覆盖 shared.env) ──
# =============================================================================
# saas-service.env.tpl — SaaS 后端独有变量
# 与 shared.env 合并后生成 saas-service.env
# 由 generate-envs.sh 自动处理
# =============================================================================

# --- 基础 ---
APP_BASE_URL=https://your-domain.com
ENV=production
MASTER_KEY=<请替换>
ENABLE_SWAGGER_UI=false

# --- Redis 专属配置 ---
REDIS_KEY_PREFIX=alephant:
REDIS_LOCK_DEFAULT_TTL_SECONDS=30
REDIS_LOCK_RENEW_INTERVAL_SECONDS=10
REDIS_STRONG_COORDINATION=true
IDEMPOTENCY_TTL_SECONDS=86400
LAST_USED_DEBOUNCE_SECONDS=5

# --- Cookie / Session ---
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_HTTP_ONLY=true
REFRESH_COOKIE_SAME_SITE=lax
REFRESH_COOKIE_SECURE=true

# --- JWT ---
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
CSRF_TOKEN_TTL=3600

# --- Stripe 支付 ---
STRIPE_SECRET_KEY=<请替换>
STRIPE_WEBHOOK_SECRET=<请替换>
STRIPE_PRICE_PRO_MONTHLY=<请替换>
STRIPE_PRICE_PRO_YEARLY=<请替换>
STRIPE_PRICE_TEAM_MONTHLY=<请替换>
STRIPE_PRICE_TEAM_YEARLY=<请替换>
STRIPE_PRICE_ENTERPRISE_MONTHLY=<请替换>
STRIPE_PRICE_ENTERPRISE_YEARLY=<请替换>
STRIPE_PRICE_EXTRA_VK=<请替换>
STRIPE_PRICE_LOG_PACK_PRO=<请替换>
STRIPE_PRICE_LOG_PACK_TEAM=<请替换>
STRIPE_PRICE_LOG_PACK_ENTERPRISE=<请替换>
STRIPE_METER_EVENT_LOG_PACK_PRO=<请替换>
STRIPE_METER_EVENT_LOG_PACK_TEAM=<请替换>
STRIPE_METER_EVENT_LOG_PACK_ENTERPRISE=<请替换>

# --- OAuth ---
OAUTH_GITHUB_CLIENT_ID=<请替换>
OAUTH_GITHUB_CLIENT_SECRET=<请替换>
OAUTH_GOOGLE_CLIENT_ID=<请替换>
OAUTH_GOOGLE_CLIENT_SECRET=<请替换>
OAUTH_GITHUB_ALLOWED_REDIRECT_URIS=<请替换>

# --- Managed Wallets 独有 ---
MANAGED_WALLETS_API_ENABLED=true
MANAGED_WALLETS_DAILY_WITHDRAW_LIMIT=<请替换>
MANAGED_WALLETS_MAX_WITHDRAW_AMOUNT=<请替换>

# --- Payment ---
PAYMENT_SERVICE_BASE_URL=http://ledge-service:8080
PAYMENT_LEDGER_GRPC_ADDR=ledge-service:9090
PAYMENT_LEDGER_INTERNAL_TOKEN=<请替换>

# --- Policy ---
POLICY_STREAM_MAXLEN=10000

# --- Analytics / Logs ---
COLLECTOR_ANALYTICS_BASE_URL=http://logs-collector:8585
LOG_OVERAGE_E2E_METER_EVENT_NAME=
LOG_OVERAGE_E2E_REAL_STRIPE=false
LOG_OVERAGE_E2E_STRIPE_CUSTOMER_ID=
REVENUE_WITHDRAW_API_ENABLED=true

# --- 其他 ---
ENFORCE_TRIAL_ONCE_PER_USER=false
AUTH_RATE_LIMIT_PER_MIN=60
SALES_LEAD_EMAIL=<请替换>
